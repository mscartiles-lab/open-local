{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "resourceClass": "medium",
      "node": "20.19.4",
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "mvp-upload.replit.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "622CLN8RK7"
      }
    }
  }
}